{
  "name": "@locusai/locus-telegram",
  "version": "0.22.9",
  "description": "Remote-control Locus via Telegram with full CLI mapping, git operations, and PM2 management",
  "type": "module",
  "bin": {
    "locus-telegram": "./bin/locus-telegram.js"
  },
  "files": [
    "bin",
    "package.json",
    "README.md"
  ],
  "locus": {
    "displayName": "Telegram",
    "description": "Remote-control your Locus agent from Telegram",
    "commands": [
      "telegram"
    ],
    "version": "0.1.0"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outfile bin/locus-telegram.js --target node",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@locusai/sdk": "^0.22.9",
    "grammy": "^1.35.0",
    "pm2": "^6.0.5"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "keywords": [
    "locusai-package",
    "locus",
    "telegram"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
