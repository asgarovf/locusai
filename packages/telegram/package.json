{
  "name": "@locusai/locus-telegram",
  "version": "0.21.6",
  "description": "Remote-control Locus via Telegram with full CLI mapping, git operations, and PM2 management",
  "type": "module",
  "bin": {
    "locus-telegram": "./bin/locus-telegram.js"
